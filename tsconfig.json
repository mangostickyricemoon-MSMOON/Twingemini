{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]   // ✅ สำคัญ: เพิ่ม node + vite/client
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
